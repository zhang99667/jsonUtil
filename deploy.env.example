# Docker Compose 部署环境变量示例
# 使用方式：复制为 .env 后按生产环境修改，再执行 docker compose up -d --build

POSTGRES_DB=jsonhelper
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-postgres-password

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/jsonhelper
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me-to-a-strong-postgres-password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# 生产环境必须替换为足够长的随机值
JWT_SECRET=change-me-to-a-long-random-base64-secret
JWT_EXPIRATION=86400000
