{
  "name": "json-helper-ai-fix",
  "productName": "JSONUtils - 专业版",
  "private": true,
  "version": "1.8.540",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint \"{src,config}/**/*.{ts,tsx}\" --quiet",
    "lint:report": "eslint \"{src,config}/**/*.{ts,tsx}\"",
    "audit:security": "npm audit --audit-level=moderate",
    "typecheck": "tsc --noEmit",
    "check:preloads": "node scripts/check-main-preloads.mjs",
    "corpus:scheme": "vitest run src/utils/schemeCorpus.test.ts",
    "corpus:snapshot": "node scripts/scheme-corpus-snapshot.mjs",
    "corpus:snapshot:check": "node scripts/scheme-corpus-snapshot.mjs --strict",
    "corpus:snapshot:baseline": "node scripts/scheme-corpus-snapshot.mjs --strict --fail-before-write --output fixtures/scheme-corpus/corpus-quality.baseline.snapshot.json",
    "corpus:snapshot:diff": "node scripts/scheme-corpus-snapshot-diff.mjs",
    "corpus:promote": "node scripts/scheme-corpus-promote.mjs",
    "perf:scheme": "node scripts/scheme-performance-budget.mjs",
    "perf:jsonpath": "node scripts/jsonpath-performance-budget.mjs",
    "perf:e2e": "playwright test --config playwright.performance.config.ts",
    "samples:to-regression": "node scripts/issue-samples-to-regression.mjs",
    "cmd:diff": "node scripts/cmd-structure-diff.mjs",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "build:all": "./deploy-ci.sh -p all",
    "build:web": "./deploy-ci.sh -p web",
    "build:electron": "./deploy-ci.sh -p electron",
    "deploy:web": "./deploy-web.sh",
    "ci:test": "./deploy-ci.sh -p web -v \"ci-$(date +%Y%m%d)\"",
    "ci:release": "./deploy-ci.sh -p all -v \"$(git describe --tags --abbrev=0 2>/dev/null || echo '0.0.0')\""
  },
  "build": {
    "appId": "com.example.jsonhelper",
    "productName": "JSONUtils - 专业版",
    "copyright": "Copyright © 2025",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "build"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@google/genai": "^1.30.0",
    "@monaco-editor/react": "^4.7.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "antd": "^6.1.3",
    "axios": "^1.13.2",
    "diff": "^8.0.3",
    "driver.js": "^1.4.0",
    "json-source-map": "^0.6.1",
    "jsonpath-plus": "^10.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.50.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.53.3"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "shell-quote": "1.8.4"
  }
}
